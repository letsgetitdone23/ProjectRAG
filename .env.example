# Environment Variables for Mutual Fund RAG System
# Copy this file to .env and fill in your API keys

# ===========================================
# LLM Configuration
# ===========================================

# Groq API Key (Primary LLM - Ultra Fast)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (Fallback LLM)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# Vector Database Configuration
# ===========================================

# ChromaDB Cloud Configuration (Optional - for cloud storage)
CHROMA_HOST=your_chroma_host_here
CHROMA_PORT=8000
CHROMA_API_KEY=your_chroma_api_key_here

# Pinecone Configuration (Optional - alternative vector store)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here

# Weaviate Configuration (Optional - alternative vector store)
WEAVIATE_API_KEY=your_weaviate_api_key_here
WEAVIATE_URL=your_weaviate_url_here

# ===========================================
# Scraping Configuration
# ===========================================

# User-Agent for web scraping
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Scraping delays (in seconds)
SCRAPE_DELAY=1.0
MAX_RETRIES=3

# ===========================================
# Database Configuration
# ===========================================

# SQLite Database Path
DATABASE_PATH=./data/vector_store.db

# Data storage paths
DATA_DIR=./data
CHUNKS_DIR=./data/chunks
EMBEDDINGS_DIR=./data/embeddings
SESSIONS_DIR=./data/sessions

# ===========================================
# API Configuration
# ===========================================

# API Gateway Settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# CORS Settings
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ===========================================
# System Configuration
# ===========================================

# Logging Level
LOG_LEVEL=INFO

# Multi-thread Settings
MAX_THREADS=5
MAX_CONCURRENT_CONVERSATIONS=10
SESSION_TIMEOUT_HOURS=24

# ===========================================
# Performance Configuration
# ===========================================

# Embedding Settings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=512

# Vector Store Settings
VECTOR_STORE_TYPE=sqlite
VECTOR_STORE_DIMENSION=1024
VECTOR_STORE_METRIC=cosine

# ===========================================
# Security Configuration
# ===========================================

# JWT Secret for API authentication (optional)
JWT_SECRET=your_jwt_secret_here

# Encryption key for sensitive data (optional)
ENCRYPTION_KEY=your_encryption_key_here

# ===========================================
# Monitoring Configuration
# ===========================================

# Prometheus Metrics
PROMETHEUS_PORT=9090

# Health Check Settings
HEALTH_CHECK_INTERVAL=30

# ===========================================
# Development Configuration
# ===========================================

# Development Mode
DEVELOPMENT_MODE=false

# Testing Settings
TEST_QUERIES_ENABLED=true
TEST_QUERIES_COUNT=5

# ===========================================
# Deployment Configuration
# ===========================================

# Docker Settings
DOCKER_REGISTRY=your-registry
DOCKER_TAG=latest

# Kubernetes Settings
K8S_NAMESPACE=rag-system
K8S_REPLICAS=3

# ===========================================
# Backup Configuration
# ===========================================

# Backup Settings
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Cloud Storage (optional)
AWS_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
